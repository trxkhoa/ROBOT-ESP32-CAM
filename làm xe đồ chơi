Code Arduino hoàn chỉnh

Code dưới đây đã bỏ phần line follower, chỉ giữ lại phần tránh vật cản bằng siêu âm + xoay thân xe.

#include <Servo.h>

// ==========================
// L298N Motor Driver
// ==========================
#define enA 10   // PWM motor trái
#define in1 9
#define in2 8
#define in3 7
#define in4 6
#define enB 5    // PWM motor phải

// ==========================
// Ultrasonic Sensor HC-SR04
// ==========================
#define echoPin A2
#define trigPin A3

// ==========================
// 2 Servo lau nhà
// Dùng servo thường 180 độ
// ==========================
#define SERVO_LEFT_PIN 11
#define SERVO_RIGHT_PIN 12

Servo servoLeft;
Servo servoRight;

// ==========================
// Tham số hệ thống
// ==========================
const int obstacleDistance = 5;     // cm, ngưỡng phát hiện vật cản
const int motorSpeed = 180;         // tốc độ chạy 0-255
const int turnSpeed  = 170;         // tốc độ khi xoay
const int startDelay = 2000;        // chờ 2 giây sau khi bật nguồn

// Thời gian xoay 90 độ
// CẦN tự chỉnh thực tế theo xe của bạn
const int turn90Time = 420;         // ms, thử từ 350~550 ms tùy xe

// Thời gian lùi khi bí đường
const int backTime = 350;

// ==========================
// Biến điều khiển servo lau
// ==========================
int sweepAngle = 0;
int sweepStep = 4;
unsigned long lastSweepTime = 0;
const int sweepInterval = 25;       // ms
bool cleaningEnabled = false;

// ==========================
// Setup
// ==========================
void setup() {
  Serial.begin(9600);

  pinMode(echoPin, INPUT);
  pinMode(trigPin, OUTPUT);

  pinMode(enA, OUTPUT);
  pinMode(in1, OUTPUT);
  pinMode(in2, OUTPUT);
  pinMode(in3, OUTPUT);
  pinMode(in4, OUTPUT);
  pinMode(enB, OUTPUT);

  servoLeft.attach(SERVO_LEFT_PIN);
  servoRight.attach(SERVO_RIGHT_PIN);

  setMotorSpeed(motorSpeed, motorSpeed);
  Stop();

  // Đưa servo về vị trí ban đầu
  servoLeft.write(90);
  servoRight.write(90);

  Serial.println("Robot dang khoi dong...");
  delay(startDelay);   // chờ 2 giây theo yêu cầu

  cleaningEnabled = true;
  Serial.println("Bat dau di chuyen...");
}

// ==========================
// Loop
// ==========================
void loop() {
  updateCleaningServo();   // cho servo lau lắc liên tục khi được phép

  long distanceF = Ultrasonic_read();
  Serial.print("Front Distance = ");
  Serial.println(distanceF);

  if (distanceF <= obstacleDistance && distanceF > 0) {
    avoidObstacle();
  } else {
    forward();
  }

  delay(20);
}

// ==========================
// Hàm cập nhật servo lau
// ==========================
void updateCleaningServo() {
  if (!cleaningEnabled) return;

  unsigned long now = millis();
  if (now - lastSweepTime >= sweepInterval) {
    lastSweepTime = now;

    sweepAngle += sweepStep;

    if (sweepAngle >= 180) {
      sweepAngle = 180;
      sweepStep = -sweepStep;
    }
    if (sweepAngle <= 0) {
      sweepAngle = 0;
      sweepStep = -sweepStep;
    }

    // 2 servo có thể quay đối xứng để lau rộng hơn
    servoLeft.write(sweepAngle);
    servoRight.write(180 - sweepAngle);
  }
}

// ==========================
// Dừng servo lau
// ==========================
void stopCleaningServo() {
  cleaningEnabled = false;
  servoLeft.write(90);
  servoRight.write(90);
}

// ==========================
// Bật lại servo lau
// ==========================
void startCleaningServo() {
  cleaningEnabled = true;
}

// ==========================
// Đọc khoảng cách siêu âm
// ==========================
long Ultrasonic_read() {
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);

  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  long duration = pulseIn(echoPin, HIGH, 30000); // timeout 30ms
  if (duration == 0) return 999; // không thấy vật cản
  long distance = duration / 29 / 2;
  return distance;
}

// ==========================
// Tránh vật cản
// ==========================
void avoidObstacle() {
  Serial.println("Gap vat can -> dung lai");

  Stop();
  stopCleaningServo();
  delay(200);

  // 1. Quay trái 90 độ để kiểm tra
  Serial.println("Kiem tra ben trai...");
  rotateLeft90();
  delay(200);

  long leftDistance = Ultrasonic_read();
  Serial.print("Left check = ");
  Serial.println(leftDistance);

  if (leftDistance > obstacleDistance) {
    Serial.println("Ben trai thong, di tiep");
    startCleaningServo();
    forward();
    delay(250);
    return;
  }

  // 2. Nếu trái bị cản, quay phải 180 độ để nhìn sang phải
  Serial.println("Ben trai bi can, kiem tra ben phai...");
  rotateRight180();
  delay(200);

  long rightDistance = Ultrasonic_read();
  Serial.print("Right check = ");
  Serial.println(rightDistance);

  if (rightDistance > obstacleDistance) {
    Serial.println("Ben phai thong, di tiep");
    startCleaningServo();
    forward();
    delay(250);
    return;
  }

  // 3. Nếu cả hai bên đều bị cản, quay về giữa rồi lùi nhẹ
  Serial.println("Ca hai ben deu bi can -> lui nhe");
  rotateLeft90();   // từ hướng phải quay trái 90 để về hướng giữa
  delay(200);

  backward();
  delay(backTime);
  Stop();
  delay(200);

  startCleaningServo();
}

// ==========================
// Chỉnh tốc độ 2 bánh
// ==========================
void setMotorSpeed(int leftSpeed, int rightSpeed) {
  analogWrite(enA, constrain(leftSpeed, 0, 255));
  analogWrite(enB, constrain(rightSpeed, 0, 255));
}

// ==========================
// Điều khiển xe
// ==========================
void forward() {
  setMotorSpeed(motorSpeed, motorSpeed);

  digitalWrite(in1, LOW);
  digitalWrite(in2, HIGH);
  digitalWrite(in3, HIGH);
  digitalWrite(in4, LOW);
}

void backward() {
  setMotorSpeed(motorSpeed, motorSpeed);

  digitalWrite(in1, HIGH);
  digitalWrite(in2, LOW);
  digitalWrite(in3, LOW);
  digitalWrite(in4, HIGH);
}

void turnLeftInPlace() {
  setMotorSpeed(turnSpeed, turnSpeed);

  digitalWrite(in1, HIGH);
  digitalWrite(in2, LOW);
  digitalWrite(in3, HIGH);
  digitalWrite(in4, LOW);
}

void turnRightInPlace() {
  setMotorSpeed(turnSpeed, turnSpeed);

  digitalWrite(in1, LOW);
  digitalWrite(in2, HIGH);
  digitalWrite(in3, LOW);
  digitalWrite(in4, HIGH);
}

void Stop() {
  digitalWrite(in1, LOW);
  digitalWrite(in2, LOW);
  digitalWrite(in3, LOW);
  digitalWrite(in4, LOW);
}

// ==========================
// Xoay thân xe
// ==========================
void rotateLeft90() {
  turnLeftInPlace();
  delay(turn90Time);
  Stop();
}

void rotateRight90() {
  turnRightInPlace();
  delay(turn90Time);
  Stop();
}

void rotateRight180() {
  turnRightInPlace();
  delay(turn90Time * 2);
  Stop();
}
