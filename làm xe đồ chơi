1) Code nâng cấp hoàn chỉnh
#include <Servo.h>

// =====================================================
// PIN KET NOI
// =====================================================
#define enA 10
#define in1 9
#define in2 8
#define in3 7
#define in4 6
#define enB 5

#define echoPin A2
#define trigPin A3

#define SERVO_LEFT_PIN 11
#define SERVO_RIGHT_PIN 12

// =====================================================
// DOI TUONG SERVO
// =====================================================
Servo servoLeft;
Servo servoRight;

// =====================================================
// THAM SO HE THONG
// =====================================================
const int obstacleDistance = 5;      // cm
const int motorSpeedForward = 180;
const int motorSpeedTurn    = 170;
const int motorSpeedBack    = 160;

const unsigned long startupWait = 2000;   // cho 2s luc bat nguon
const unsigned long stopPause   = 200;    // dung lai truoc khi quyet dinh
const unsigned long turn90Time  = 420;    // canh chinh thuc te
const unsigned long backTime    = 350;    // lui khi bi ca 2 ben
const unsigned long moveResumeTime = 250; // chay them sau khi tim duoc huong

// Servo lau
bool cleaningEnabled = false;
int sweepAngle = 0;
int sweepStep = 4;
unsigned long lastSweepMillis = 0;
const unsigned long sweepInterval = 25;

// =====================================================
// STATE MACHINE
// =====================================================
enum RobotState {
  STARTUP_WAIT,
  MOVING_FORWARD,
  OBSTACLE_STOP,
  CHECK_LEFT_TURN,
  CHECK_LEFT_MEASURE,
  CHECK_RIGHT_TURN,
  CHECK_RIGHT_MEASURE,
  RETURN_CENTER_AND_BACK,
  RESUME_MOVE
};

RobotState state = STARTUP_WAIT;
unsigned long stateStartMillis = 0;

// =====================================================
// HAM HO TRO
// =====================================================
void changeState(RobotState newState) {
  state = newState;
  stateStartMillis = millis();
}

bool stateTimeReached(unsigned long durationMs) {
  return (millis() - stateStartMillis >= durationMs);
}

// =====================================================
// SETUP
// =====================================================
void setup() {
  Serial.begin(9600);

  pinMode(echoPin, INPUT);
  pinMode(trigPin, OUTPUT);

  pinMode(enA, OUTPUT);
  pinMode(in1, OUTPUT);
  pinMode(in2, OUTPUT);
  pinMode(in3, OUTPUT);
  pinMode(in4, OUTPUT);
  pinMode(enB, OUTPUT);

  servoLeft.attach(SERVO_LEFT_PIN);
  servoRight.attach(SERVO_RIGHT_PIN);

  Stop();
  setMotorSpeed(motorSpeedForward, motorSpeedForward);

  servoLeft.write(90);
  servoRight.write(90);

  Serial.println("Robot khoi dong, cho 2 giay...");
  changeState(STARTUP_WAIT);
}

// =====================================================
// LOOP CHINH
// =====================================================
void loop() {
  updateCleaningServo();

  switch (state) {
    case STARTUP_WAIT:
      Stop();
      stopCleaningServo();
      if (stateTimeReached(startupWait)) {
        Serial.println("Bat dau di chuyen");
        startCleaningServo();
        changeState(MOVING_FORWARD);
      }
      break;

    case MOVING_FORWARD: {
      long d = getStableDistance();
      Serial.print("Distance Front = ");
      Serial.println(d);

      if (d <= obstacleDistance) {
        Stop();
        stopCleaningServo();
        changeState(OBSTACLE_STOP);
      } else {
        forward();
      }
      break;
    }

    case OBSTACLE_STOP:
      Stop();
      if (stateTimeReached(stopPause)) {
        Serial.println("Gap vat can -> xoay trai 90 do de kiem tra");
        turnLeftInPlace();
        changeState(CHECK_LEFT_TURN);
      }
      break;

    case CHECK_LEFT_TURN:
      if (stateTimeReached(turn90Time)) {
        Stop();
        changeState(CHECK_LEFT_MEASURE);
      }
      break;

    case CHECK_LEFT_MEASURE: {
      long dLeft = getStableDistance();
      Serial.print("Distance Left = ");
      Serial.println(dLeft);

      if (dLeft > obstacleDistance) {
        Serial.println("Trai trong -> di tiep");
        startCleaningServo();
        forward();
        changeState(RESUME_MOVE);
      } else {
        Serial.println("Trai bi can -> xoay phai 180 do de kiem tra ben phai");
        turnRightInPlace();
        changeState(CHECK_RIGHT_TURN);
      }
      break;
    }

    case CHECK_RIGHT_TURN:
      // dang o huong trai, muon sang huong phai can quay 180
      if (stateTimeReached(turn90Time * 2)) {
        Stop();
        changeState(CHECK_RIGHT_MEASURE);
      }
      break;

    case CHECK_RIGHT_MEASURE: {
      long dRight = getStableDistance();
      Serial.print("Distance Right = ");
      Serial.println(dRight);

      if (dRight > obstacleDistance) {
        Serial.println("Phai trong -> di tiep");
        startCleaningServo();
        forward();
        changeState(RESUME_MOVE);
      } else {
        Serial.println("Ca 2 ben deu bi can -> quay ve giua va lui");
        turnLeftInPlace(); // dang o huong phai, quay trai 90 do de ve huong giua
        changeState(RETURN_CENTER_AND_BACK);
      }
      break;
    }

    case RETURN_CENTER_AND_BACK:
      if (!stateTimeReached(turn90Time)) {
        // dang quay ve giua
      } else if (stateTimeReached(turn90Time) && !stateTimeReached(turn90Time + backTime)) {
        Stop();
        backward();
      } else {
        Stop();
        startCleaningServo();
        changeState(MOVING_FORWARD);
      }
      break;

    case RESUME_MOVE:
      if (stateTimeReached(moveResumeTime)) {
        changeState(MOVING_FORWARD);
      }
      break;
  }
}

// =====================================================
// DOC CAM BIEN SIEU AM - CO LOC NHIEU
// =====================================================
long readUltrasonicRaw() {
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);

  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  long duration = pulseIn(echoPin, HIGH, 30000); // timeout 30ms
  if (duration == 0) return 999;
  return duration / 29 / 2;
}

long getStableDistance() {
  long d1 = readUltrasonicRaw();
  delay(15);
  long d2 = readUltrasonicRaw();
  delay(15);
  long d3 = readUltrasonicRaw();

  // sắp xếp 3 giá trị để lấy trung vị
  long a = d1, b = d2, c = d3;
  if (a > b) swapLong(a, b);
  if (b > c) swapLong(b, c);
  if (a > b) swapLong(a, b);

  return b; // median
}

void swapLong(long &x, long &y) {
  long t = x;
  x = y;
  y = t;
}

// =====================================================
// DIEU KHIEN 2 SERVO LAU
// =====================================================
void updateCleaningServo() {
  if (!cleaningEnabled) return;

  unsigned long now = millis();
  if (now - lastSweepMillis >= sweepInterval) {
    lastSweepMillis = now;

    sweepAngle += sweepStep;

    if (sweepAngle >= 180) {
      sweepAngle = 180;
      sweepStep = -sweepStep;
    } else if (sweepAngle <= 0) {
      sweepAngle = 0;
      sweepStep = -sweepStep;
    }

    // quay doi xung
    servoLeft.write(sweepAngle);
    servoRight.write(180 - sweepAngle);
  }
}

void startCleaningServo() {
  cleaningEnabled = true;
}

void stopCleaningServo() {
  cleaningEnabled = false;
  servoLeft.write(90);
  servoRight.write(90);
}

// =====================================================
// DIEU KHIEN MOTOR
// =====================================================
void setMotorSpeed(int leftSpeed, int rightSpeed) {
  analogWrite(enA, constrain(leftSpeed, 0, 255));
  analogWrite(enB, constrain(rightSpeed, 0, 255));
}

void forward() {
  setMotorSpeed(motorSpeedForward, motorSpeedForward);

  digitalWrite(in1, LOW);
  digitalWrite(in2, HIGH);
  digitalWrite(in3, HIGH);
  digitalWrite(in4, LOW);
}

void backward() {
  setMotorSpeed(motorSpeedBack, motorSpeedBack);

  digitalWrite(in1, HIGH);
  digitalWrite(in2, LOW);
  digitalWrite(in3, LOW);
  digitalWrite(in4, HIGH);
}

void turnLeftInPlace() {
  setMotorSpeed(motorSpeedTurn, motorSpeedTurn);

  digitalWrite(in1, HIGH);
  digitalWrite(in2, LOW);
  digitalWrite(in3, HIGH);
  digitalWrite(in4, LOW);
}

void turnRightInPlace() {
  setMotorSpeed(motorSpeedTurn, motorSpeedTurn);

  digitalWrite(in1, LOW);
  digitalWrite(in2, HIGH);
  digitalWrite(in3, LOW);
  digitalWrite(in4, HIGH);
}

void Stop() {
  digitalWrite(in1, LOW);
  digitalWrite(in2, LOW);
  digitalWrite(in3, LOW);
  digitalWrite(in4, LOW);
}
